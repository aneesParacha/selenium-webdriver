pipeline {
    agent any

    environment {
        IMAGE_NAME = "selenium-test"
    }

    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    sh 'docker build -t $IMAGE_NAME .'
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                script {
                    sh 'docker run --rm $IMAGE_NAME'
                }
            }
        }
    }

    post {
        always {
            sh 'docker system prune -af'
        }
    }
}

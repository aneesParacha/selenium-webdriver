pipeline {
    agent any

    environment {
        IMAGE_NAME = "selenium-image"
    }

    stages {
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Run Selenium Tests') {
            steps {
                sh 'docker run --rm $IMAGE_NAME'
            }
        }
    }

    post {
        always {
            sh 'docker system prune -af || true'
        }
    }
}
